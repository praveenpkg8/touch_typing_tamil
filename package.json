{
  "name": "tamil99-typing-tutor",
  "private": true,
  "version": "0.0.1",
  "description": "Privacy-first Tamil typing tutor for the Tamil99 keyboard layout. Client-only, local-first, no backend.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "mim:build": "tsx scripts/mim-to-json.ts",
    "mim:check": "tsx scripts/mim-to-json.ts --check",
    "composer:conformance": "tsx scripts/test-composer-conformance.ts",
    "validator:integration": "tsx scripts/test-validator-integration.ts",
    "predict:tests": "tsx scripts/test-predict-next-key.ts",
    "recommendation:tests": "tsx scripts/test-recommendation.ts",
    "hysteresis:tests": "tsx scripts/test-hysteresis.ts",
    "test:all": "tsx scripts/test-composer-conformance.ts && tsx scripts/test-validator-integration.ts && tsx scripts/test-predict-next-key.ts && tsx scripts/test-recommendation.ts && tsx scripts/test-hysteresis.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  }
}
